projection;
strict ( 2 );
use draft;

define behavior for ZC_VC_HEADER alias ComplaintHeader
{
  use create;
  use update;
  use delete;

  use action submitComplaint;

  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _Item { create; with draft; }
}

define behavior for ZC_VC_ITEM alias ComplaintItem
{
  use update;
  use delete;

  use association _Header { with draft; }
}